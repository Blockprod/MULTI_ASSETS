# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Configuration du Bot de Trading Crypto Multi-Assets
# ══════════════════════════════════════════════════════════════════════════════
# Copier ce fichier vers .env et remplir les valeurs.
#   cp .env.example .env
#
# Les variables marquées [REQUIS] doivent être renseignées.
# Les variables marquées [OPTIONNEL] ont des valeurs par défaut.
# ══════════════════════════════════════════════════════════════════════════════

# === BINANCE API [REQUIS] ===================================================
# Clés API Binance (créer sur https://www.binance.com/en/my/settings/api-management)
# Permissions nécessaires : Lecture + Spot Trading
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# === EMAIL ALERTS [REQUIS] ==================================================
# Serveur SMTP pour l'envoi d'alertes (Gmail recommandé)
# Pour Gmail : créer un mot de passe d'application sur https://myaccount.google.com/apppasswords
SENDER_EMAIL=your_email@gmail.com
GOOGLE_MAIL_PASSWORD=your_app_password_here
RECEIVER_EMAIL=alerts_receiver@example.com

# === SMTP CONFIGURATION [OPTIONNEL] ========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# === API SETTINGS [OPTIONNEL] ==============================================
# Timeout des requêtes API en secondes
API_TIMEOUT=30
# Nombre de workers pour les backtests parallèles
MAX_WORKERS=4

# === FRAIS & SLIPPAGE [OPTIONNEL] ==========================================
# Frais de commission Binance (décimal)
TAKER_FEE=0.0007
MAKER_FEE=0.0002
# Slippage estimé pour les ordres market
SLIPPAGE_BUY=0.0001
SLIPPAGE_SELL=0.0001

# === BACKTEST [OPTIONNEL] ==================================================
# Capital initial pour les backtests (USDC)
INITIAL_WALLET=10000.0
# Nombre de jours de données historiques pour le backtest
BACKTEST_DAYS=1825

# === STOCKAGE [OPTIONNEL] ==================================================
# Répertoire pour le cache des données historiques
CACHE_DIR=cache
# Répertoire pour les fichiers d'état du bot
STATES_DIR=states
# Nom du fichier d'état
STATE_FILE=bot_state.pkl

# === INDICATEURS TECHNIQUES [OPTIONNEL] ====================================
# Période ATR (Average True Range)
ATR_PERIOD=14
# Multiplicateur ATR pour le trailing stop
ATR_MULTIPLIER=5.5
# Multiplicateur ATR pour le stop-loss fixe
ATR_STOP_MULTIPLIER=3.0

# === RISK MANAGEMENT [OPTIONNEL] ===========================================
# Fraction du capital à risquer par trade (0.05 = 5%)
RISK_PER_TRADE=0.05
# Mode de sizing: baseline | risk | fixed_notional | volatility_parity
SIZING_MODE=baseline

# === PARTIAL EXITS [OPTIONNEL] =============================================
# Seuils de profit pour les sorties partielles (décimal)
PARTIAL_THRESHOLD_1=0.02
PARTIAL_THRESHOLD_2=0.04
# Pourcentage de la position vendu à chaque seuil
PARTIAL_PCT_1=0.50
PARTIAL_PCT_2=0.30

# === TRAILING STOP [OPTIONNEL] =============================================
# Seuil d'activation du trailing stop (décimal, 0.03 = 3%)
TRAILING_ACTIVATION_PCT=0.03
# Volatilité cible pour le mode volatility_parity
TARGET_VOLATILITY_PCT=0.02
