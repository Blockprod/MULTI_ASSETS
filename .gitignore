# Environnement virtuel
.venv/
venv/
env/

# Variables d'environnement (API keys, secrets)
.env

# Python cache
__pycache__/
*.pyc
*.pyo

# Fichiers compilés Cython / C++
*.cpp
*.so
*.pyd

# État du bot (pickle)
*.pkl
states/
code/states/

# Logs
*.log
code/logs/

# Données de trading (runtime artifacts — ne jamais committer)
*.csv
*.meta.json

# Cache de données
cache/
code/cache/

# IDE
.vscode/*.code-workspace
.idea/

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Build artifacts
code/build/
build/

# Rapports d'analyse statique et sorties de tests
reports/

# Couverture de code
.coverage

# Sorties de tests locales
test_output*.txt
tests_output*.txt
test_run.txt

# Logs bot générés à la racine
log_bot.md

# Caches d'outils d'analyse statique
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Artefacts runtime dans code/src/
code/src/states/
code/src/logs/
code/src/cache/

# Fichiers temporaires outils (pyright, etc.)
*.tmp

# Artefacts binaires locaux
*.old

# Fichiers de verrou runtime
*.lock

# Metriques runtime locales
metrics/
