{
  // ── Python / Pylance ────────────────────────────────────────────────────
  // La config d'analyse (include, exclude, typeCheckingMode, stubs, extraPaths)
  // est gérée par pyrightconfig.json à la racine (priorité sur python.analysis.*)
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",

  // Analyse tout le workspace en arrière-plan (pas seulement les fichiers ouverts)
  "python.analysis.diagnosticMode": "workspace",

  // ── Éditeur ─────────────────────────────────────────────────────────────
  "editor.rulers": [100],
  "files.associations": {
    "*.pyx": "python",
    "*.pxd": "python"
  }
}
